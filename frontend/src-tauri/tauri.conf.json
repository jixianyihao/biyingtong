{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "必赢通",
  "version": "5.0.0",
  "identifier": "com.biyingtong.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "必赢通 · BiYingTong",
        "width": 1440,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 720,
        "decorations": true,
        "resizable": true,
        "fullscreen": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Finance",
    "shortDescription": "量化交易终端",
    "longDescription": "必赢通 · 基于 LLM 的 A股智能交易终端。整合策略研发 / 多 agent 回测 / 实时风控。"
  }
}
